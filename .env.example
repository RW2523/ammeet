# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ammeet:ammeet_secret@localhost:5432/ammeet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported: openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# ── Embedding model (used for pgvector RAG) ───────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── File storage (local path or S3 bucket) ────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# AWS_S3_BUCKET=ammeet-uploads
# AWS_REGION=us-east-1

# ── STT — Speech-to-Text ──────────────────────────────────────────────────────
# mock      : returns a fixture transcript (no API needed, good for dev)
# whisper   : OpenAI Whisper API (uses OPENAI_API_KEY above, batch file upload)
# assemblyai: AssemblyAI real-time WebSocket streaming (set ASSEMBLYAI_API_KEY)
STT_PROVIDER=mock
# ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# ── TTS — Text-to-Speech ──────────────────────────────────────────────────────
# none  : silent mock (returns empty bytes)
# openai: OpenAI TTS API (uses OPENAI_API_KEY above)
TTS_PROVIDER=openai
# Voice options: alloy | echo | fable | nova | onyx | shimmer
TTS_VOICE=nova

# ── Meeting Bot ───────────────────────────────────────────────────────────────
# mock   : simulated bot — no real meeting join (good for dev/demo)
# recall : Recall.ai bot — joins real Zoom / Google Meet / Teams (needs key + public webhook)
# browser: self-hosted headless-browser bot (the bot-worker service) — joins real
#          Zoom/Meet/Teams/Jitsi with NO third-party key; no public webhook needed
#          (worker + backend co-located). Run: docker compose --profile bots up bot-worker
BOT_PROVIDER=mock
# RECALL_API_KEY=your-recall-api-key
# RECALL_API_BASE=https://us-east-1.recall.ai/api/v1
# BROWSER_BOT_WORKER_URL=http://localhost:4500   # or http://bot-worker:4500 in compose
#
# Publicly reachable URL that Recall.ai will POST webhooks to.
# For local dev use ngrok: ngrok http 8000 → set WEBHOOK_BASE_URL=https://xxxx.ngrok.io
# WEBHOOK_BASE_URL=https://your-production-domain.com

# ── Integrations (OAuth) ──────────────────────────────────────────────────────
# Leave empty to keep a provider in mock mode. Set client credentials to enable
# the real OAuth connect flow on the workspace Integrations page.
# Google Cloud Console → OAuth client (redirect: {WEBHOOK_BASE_URL}/api/integrations/oauth/google_calendar/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Slack app (https://api.slack.com/apps, redirect: .../oauth/slack/callback, scopes: chat:write,channels:read,channels:join)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# Atlassian developer console 3LO app (redirect: .../oauth/jira/callback, scopes: read:jira-work offline_access)
# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=
# Microsoft Teams / 365 — Azure AD app registration (Azure Portal → App registrations)
#   redirect URI: {WEBHOOK_BASE_URL}/api/integrations/oauth/microsoft_teams/callback
#   delegated Microsoft Graph permissions: offline_access, User.Read, Calendars.Read
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=common   # "common" | "organizations" | your tenant id

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Leave empty for mock billing (plan changes apply instantly without payment).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...      (webhook endpoint: {API}/api/billing/webhook)
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_TEAM_MONTHLY=price_...

# ── Email ─────────────────────────────────────────────────────────────────────
# console: log emails to stdout (dev). smtp: real delivery.
EMAIL_PROVIDER=console
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=AmMeeting <no-reply@yourdomain.com>
# Require verified email before login (enable in production once SMTP works)
REQUIRE_EMAIL_VERIFICATION=false

# ── Auth hardening ────────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=10
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_AUTH_PER_MINUTE=10
# Fernet key for encrypting integration tokens at rest (generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# Falls back to a key derived from SECRET_KEY when empty.
# TOKEN_ENCRYPTION_KEY=

# ── Auto-join scheduler ───────────────────────────────────────────────────────
# Background worker that deploys the proxy bot at a meeting's scheduled start time
# (for proxy meetings with consent, a meeting link, and auto-join enabled).
AUTO_JOIN_SCHEDULER_ENABLED=true
AUTO_JOIN_POLL_SECONDS=60
AUTO_JOIN_LEAD_MINUTES=2
AUTO_JOIN_GRACE_MINUTES=5

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Frontend base URL — used in OAuth redirects and email links
FRONTEND_URL=http://localhost:3000
