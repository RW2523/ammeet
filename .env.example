# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ammeet:ammeet_secret@localhost:5432/ammeet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported: openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# ── Embedding model (used for pgvector RAG) ───────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── File storage (local path or S3 bucket) ────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# AWS_S3_BUCKET=ammeet-uploads
# AWS_REGION=us-east-1

# ── Stub integrations ─────────────────────────────────────────────────────────
# Set to "real" later once OAuth creds are wired
JIRA_PROVIDER=mock
CALENDAR_PROVIDER=mock
SLACK_PROVIDER=mock
STT_PROVIDER=mock

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
