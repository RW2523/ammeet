# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ammeet:ammeet_secret@localhost:5432/ammeet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported: openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# ── Embedding model (used for pgvector RAG) ───────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── File storage (local path or S3 bucket) ────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# AWS_S3_BUCKET=ammeet-uploads
# AWS_REGION=us-east-1

# ── STT — Speech-to-Text ──────────────────────────────────────────────────────
# mock      : returns a fixture transcript (no API needed, good for dev)
# whisper   : OpenAI Whisper API (uses OPENAI_API_KEY above, batch file upload)
# assemblyai: AssemblyAI real-time WebSocket streaming (set ASSEMBLYAI_API_KEY)
STT_PROVIDER=mock
# ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# ── TTS — Text-to-Speech ──────────────────────────────────────────────────────
# none  : silent mock (returns empty bytes)
# openai: OpenAI TTS API (uses OPENAI_API_KEY above)
TTS_PROVIDER=openai
# Voice options: alloy | echo | fable | nova | onyx | shimmer
TTS_VOICE=nova

# ── Meeting Bot ───────────────────────────────────────────────────────────────
# mock  : simulated bot — no real meeting join (good for dev/demo)
# recall: Recall.ai bot — joins real Zoom / Google Meet / Teams meetings
#   Get your API key at https://www.recall.ai
#   The bot records, transcribes, and can speak in the meeting.
BOT_PROVIDER=mock
# RECALL_API_KEY=your-recall-api-key
# RECALL_API_BASE=https://us-east-1.recall.ai/api/v1
#
# Publicly reachable URL that Recall.ai will POST webhooks to.
# For local dev use ngrok: ngrok http 8000 → set WEBHOOK_BASE_URL=https://xxxx.ngrok.io
# WEBHOOK_BASE_URL=https://your-production-domain.com

# ── Stub integrations ─────────────────────────────────────────────────────────
# Set to "real" later once OAuth creds are wired
JIRA_PROVIDER=mock
CALENDAR_PROVIDER=mock
SLACK_PROVIDER=mock

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
